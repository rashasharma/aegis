# Alpaca API Credentials for Real-Time Stock Market Feed
# Sign up at https://alpaca.markets/ (Free Paper Trading account provides real-time IEX feed)
# Once you have your credentials, copy this file to '.env' and fill in your values.

ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here
ALPACA_FEED=iex # Use 'iex' for free/paper tier, 'sip' for paid live tier
